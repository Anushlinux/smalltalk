{
  "name": "smalltalk-resume-bookmark",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A WXT browser extension that helps users resume research from the exact right paragraph.",
  "scripts": {
    "dev": "wxt",
    "dev:chrome": "wxt -b chrome",
    "build": "wxt build",
    "zip": "wxt zip",
    "compile": "wxt prepare && tsc --noEmit",
    "test": "wxt prepare && vitest run",
    "proxy": "tsx server/inference-proxy.ts"
  },
  "dependencies": {
    "@wxt-dev/module-react": "^1.1.3",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wxt": "^0.19.20"
  }
}
