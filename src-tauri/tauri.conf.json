{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "smalltalk",
  "mainBinaryName": "smalltalk",
  "version": "0.1.7",
  "identifier": "com.smalltalk.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bash src-tauri/scripts/prepare_tauri_build.sh",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "smalltalk",
        "width": 800,
        "height": 600,
        "titleBarStyle": "Transparent",
        "theme": "Light"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["smalltalk"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIzOEMxRTc3NTkxREUyQzUKUldURjRoMVpkeDZNczY4WWdVNVRFTHNPUUdiU2dQSW1tb3BteFF4dkhKeGYvUnlncnB4cmRzWWcK",
      "endpoints": [
        "https://github.com/Anushlinux/smalltalk/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": [
      "resources/fonts/InstrumentSerif-Regular.ttf",
      "resources/fonts/InstrumentSerif-OFL.txt"
    ],
    "externalBin": [
      "binaries/capture_events",
      "binaries/window_snapshot",
      "binaries/accessibility_snapshot",
      "binaries/vision_ocr",
      "binaries/sck_screenshot",
      "binaries/image_mask"
    ],
    "macOS": {
      "hardenedRuntime": true,
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
