{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "smalltalk.mfti_04.manual_macos_qa.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "scenarios"],
  "properties": {
    "schema": {"const":"smalltalk.mfti_04.manual_macos_qa.v1"},
    "scenarios": {"type":"array","minItems":10,"maxItems":10,"items":{
      "type":"object","additionalProperties":false,
      "required":["scenario_id","status","reviewer","app_build_commit","expected_result","actual_result","provider","model","evidence_ids"],
      "properties": {
        "scenario_id":{"type":"string","minLength":1}, "status":{"const":"passed"},
        "reviewer":{"type":"string","minLength":1}, "app_build_commit":{"type":"string","minLength":1},
        "expected_result":{"type":"string","minLength":1}, "actual_result":{"type":"string","minLength":1},
        "provider":{"type":"string","minLength":1}, "model":{"type":"string","minLength":1},
        "evidence_ids":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}}
      }
    }}
  }
}
